    {
      "name": "Negative Case/ Zero quantity",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Cart is created even with zero quantity (no validation present)\", () => {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "let price = parseFloat(pm.environment.get(\"product1_price\"));",
              "let expectedTotal = price * 0; ",
              "",
              "console.log(`Expected amount should be: ${expectedTotal}`);",
              "console.log(`Actual API amount is: ${jsonData.total}`);",
              "",
              "pm.test(\"API does not prevent zero quantity - potential business rule issue\", () => {",
              "   pm.expect(jsonData.total).to.not.eql(expectedTotal);",
              "    ",
              "});",
              "",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "packages": {},
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": {{userId}},\n  \"products\": [\n    { \"id\": {{product1_id}}, \"quantity\": 0}\n    \n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/carts/add",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "carts",
            "add"
          ]
        }
      },
