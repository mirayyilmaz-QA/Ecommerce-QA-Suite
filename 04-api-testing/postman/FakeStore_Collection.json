{
  "info": {
    "_postman_id": "87d44bf9-1fbe-4072-acd5-8fa7bc6c5777",
    "name": "Api-FakeStore",
    "description": "API regression suite for FakeStoreAPI demonstrating auth flow, schema validation, and E2E cart management.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "36724666",
