    {
      "name": "Edge Case /OutofStock",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "",
              "let price = parseFloat(pm.environment.get(\"product1_price\"));",
              "let quantity = parseInt(pm.environment.get(\"highQuantity\"));",
              "let stock = parseInt(pm.environment.get(\"product1_stock\"));",
              "",
              "let expectedTotal = Number((price * quantity).toFixed(2));",
              "",
              "pm.test(\"Status code is 201 - cart created\", () => {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Test data validation: quantity exceeds stock\", () => {",
              "    pm.expect(quantity).to.be.above(stock);",
              "});",
              "",
              "//API calculates total based on requested quantity (ignores stock)-Business rule gap",
              "pm.test(\"API calculates total using requested quantity\", () => {",
              "    pm.expect(jsonData.total).to.eql(expectedTotal);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
